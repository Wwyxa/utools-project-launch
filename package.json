{
  "name": "utools-project-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3421 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "validate:ai-reasoning": "node scripts/validate-ai-reasoning.mjs",
    "validate:markdown-images": "node scripts/validate-markdown-images.mjs",
    "validate:project-files": "node scripts/validate-project-files.mjs",
    "validate:project-storage": "node scripts/validate-project-storage-compat.mjs",
    "validate:process-results": "node scripts/validate-process-result-batches.mjs"
  },
  "dependencies": {
    "@types/markdown-it": "^14.1.2",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "lucide-vue-next": "^0.479.0",
    "markdown-it": "^14.1.1",
    "pinia": "^2.3.1",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.13",
    "vue-markdown-render": "^2.2.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
